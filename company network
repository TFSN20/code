# ===========================================

class SniPreChecker:
    def __init__(self):
        # 缓存最终决定的最佳 SNI
        self.active_sni_cache = {}
        
        # 对配置按域名长度排序，保证长域名优先匹配
        self.sorted_rules = sorted(SNI_CONFIG.items(), key=lambda x: len(x[0]), reverse=True)
        
        # 标记是否正在初始化检测
        self.is_checking = False

    # 修正点：去掉了 loader 类型标注，兼容所有版本
    def load(self, loader):
        """
        脚本加载时触发：启动后台检测线程
        """
        ctx.log.info("正在启动 SNI 初始化检查线程...")
        t = threading.Thread(target=self.run_startup_checks)
        t.daemon = True
        t.start()

    def request(self, flow: http.HTTPFlow) -> None:
        """
        请求拦截：应用缓存的最佳 SNI
        """
        host = flow.request.host
        
        # 查找匹配规则
        matched_suffix = None
        for suffix, _ in self.sorted_rules:
            if host.endswith(suffix):
                matched_suffix = suffix
                break
        
        if matched_suffix:
            # 如果检测还没完成，先临时用列表第一个，或者直连
            # 这里选择：如果有缓存用缓存，没缓存(还在测)就用列表第一个
            if matched_suffix in self.active_sni_cache:
                chosen_sni = self.active_sni_cache[matched_suffix]
            else:
                # 降级策略：使用配置列表的第一个作为临时方案
                candidates = SNI_CONFIG[matched_suffix]
                chosen_sni = candidates[0] if candidates else None
            
            if chosen_sni:
                flow.server_conn.sni = chosen_sni

    def verify_sni_once(self, target_host, sni_candidate):
        """执行一次连接测试"""
        context = ssl.create_default_context()
        context.check_hostname = False
        context.verify_mode = ssl.CERT_NONE
        actual_sni = sni_candidate if sni_candidate else target_host
        
        start_time = time.time()
        sock = None
        try:
            # 构造探测目标
            probe_host = target_host
            if probe_host.startswith("."): 
                probe_host = "www" + probe_host
                
            sock = socket.create_connection((probe_host, 443), timeout=TEST_TIMEOUT)
            with context.wrap_socket(sock, server_hostname=actual_sni) as ssock:
                # 发送 HEAD 请求
                request = f"HEAD / HTTP/1.1\r\nHost: {probe_host}\r\nConnection: close\r\n\r\n"
                ssock.write(request.encode('utf-8'))
                ssock.read(1024) # 读取响应
                return True, (time.time() - start_time) * 1000 # 返回耗时ms
        except Exception:
            return False, 0
        finally:
            if sock:
                try:
                    sock.close()
                except:
                    pass

    def run_startup_checks(self):
        """
        核心逻辑：遍历测试并生成报告
        """
        self.is_checking = True
        
        # 最终报告的缓冲区
        report_lines = []
        report_lines.append(f"\n{'='*20} SNI 初始化可用性报告 {'='*20}")
        report_lines.append(f"检测配置: 每个 SNI 测试 {CHECK_TIMES} 次")
        report_lines.append("-" * 70)
        report_lines.append(f"{'域名后缀':<20} | {'SNI 候选':<25} | {'成功率':<8} | {'平均延迟':<8}")
        report_lines.append("-" * 70)

        # 遍历所有配置规则
        for suffix, candidates in self.sorted_rules:
            probe_target = "www" + suffix
            
            best_sni = None
            best_success_rate = -1
            best_latency = 99999

            # 遍历该域名的所有 SNI 候选者
            for sni in candidates:
                success_count = 0
                total_latency = 0
                
                # 多次测试
                for _ in range(CHECK_TIMES):
                    ok, latency = self.verify_sni_once(probe_target, sni)
                    if ok:
                        success_count += 1
                        total_latency += latency
                    time.sleep(0.1)

                # 统计结果
                success_rate = int((success_count / CHECK_TIMES) * 100)
                avg_latency = int(total_latency / success_count) if success_count > 0 else 0
                
                display_sni = sni if sni else "None(直连)"
                
                # 添加到报告行
                if success_rate > 0:
                    report_lines.append(f"{suffix:<20} | {display_sni:<25} | {success_rate}%     | {avg_latency}ms")
                else:
                    report_lines.append(f"{suffix:<20} | {display_sni:<25} | 0%       | ---")

                # 评选最佳 SNI
                if success_rate > best_success_rate:
                    best_success_rate = success_rate
                    best_latency = avg_latency
                    best_sni = sni
                elif success_rate == best_success_rate and success_rate > 0:
                    if avg_latency < best_latency:
                        best_latency = avg_latency
                        best_sni = sni
            
            # 分隔线
            report_lines.append("-" * 70)

            # 更新缓存
            if best_sni is not None and best_success_rate > 0:
                self.active_sni_cache[suffix] = best_sni
                report_lines.append(f"   ✅ [{suffix}] 最终选用: {best_sni if best_sni else '直连'}")
            else:
                fallback = candidates[0] if candidates else None
                self.active_sni_cache[suffix] = fallback
                report_lines.append(f"   ❌ [{suffix}] 全部失败，降级使用: {fallback}")
            report_lines.append("=" * 70)

        # 打印完整报告
        final_report = "\n".join(report_lines)
        ctx.log.alert(final_report)
        
        self.is_checking = False

