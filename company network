class SniAutoSwitcher:
    def __init__(self):
        self.sorted_rules = sorted(SNI_CONFIG.items(), key=lambda x: len(x[0]), reverse=True)
        self.active_sni_cache = {}
        self.testing_flags = set()
        self.lock = threading.Lock()

    def get_config_for_host(self, host: str):
        for suffix, candidates in self.sorted_rules:
            if host.endswith(suffix):
                return suffix, candidates
        return None, None

    def request(self, flow: http.HTTPFlow) -> None:
        host = flow.request.host
        suffix, candidates = self.get_config_for_host(host)
        if suffix:
            # 优先读缓存，没有缓存用第一个
            chosen_sni = self.active_sni_cache.get(suffix, candidates[0])
            if chosen_sni:
                flow.server_conn.sni = chosen_sni

    def error(self, flow: http.HTTPFlow) -> None:
        host = flow.request.host
        suffix, candidates = self.get_config_for_host(host)

        if suffix and candidates:
            with self.lock:
                if suffix in self.testing_flags:
                    return
                self.testing_flags.add(suffix)
            
            # 启动测试线程
            t = threading.Thread(target=self.run_connectivity_tests, args=(host, suffix, candidates))
            t.daemon = True
            t.start()

    def verify_sni_connectivity(self, target_host, sni_candidate):
        """测试单个 SNI 连通性"""
        context = ssl.create_default_context()
        context.check_hostname = False
        context.verify_mode = ssl.CERT_NONE
        actual_sni = sni_candidate if sni_candidate else target_host
        
        try:
            sock = socket.create_connection((target_host, 443), timeout=TEST_TIMEOUT)
            with context.wrap_socket(sock, server_hostname=actual_sni) as ssock:
                request = f"HEAD / HTTP/1.1\r\nHost: {target_host}\r\nConnection: close\r\n\r\n"
                ssock.write(request.encode('utf-8'))
                ssock.read(1024) # 能读到数据就算通
                return True, "OK"
        except Exception as e:
            # 简化错误信息，只保留关键部分
            # err_msg = str(e).split(':')[-1].strip() if ':' in str(e) else str(e)
            # return False, err_msg
            
            # 打印完整的错误类型和内容，而不仅仅是最后一部分
            err_msg = f"{type(e).__name__}: {e}" 
            return False, err_msg
        finally:
            try:
                sock.close()
            except:
                pass

    def run_connectivity_tests(self, target_host, suffix, candidates):
        """
        后台测试逻辑 - 改进版：缓冲输出，一次性打印
        """
        # 1. 初始化报告缓冲区
        timestamp = datetime.datetime.now().strftime("%H:%M:%S")
        report_buffer = []
        report_buffer.append(f"\n{'='*10} SNI 测试报告 [{timestamp}] {'='*10}")
        report_buffer.append(f"目标域名: {target_host}")
        report_buffer.append(f"匹配规则: {suffix}")
        report_buffer.append("-" * 50)
        report_buffer.append(f"{'候选 SNI':<25} | {'状态':<4} | {'详情'}")
        report_buffer.append("-" * 50)

        working_snis = []

        # 2. 逐个测试 (不打印，只存入 buffer)
        for sni in candidates:
            display_name = sni if sni else "None (直连)"
            is_success, msg = self.verify_sni_connectivity(target_host, sni)
            
            status_icon = "✅" if is_success else "❌"
            # 将结果行添加到缓冲区
            report_buffer.append(f"{display_name:<25} | {status_icon:<4} | {msg}")
            
            if is_success:
                working_snis.append(sni)

        # 3. 决策与结尾
        best_sni = None
        if working_snis:
            best_sni = working_snis[0]
            with self.lock:
                self.active_sni_cache[suffix] = best_sni
            result_msg = f"策略更新 -> 已切换至: {best_sni if best_sni else '直连'}"
        else:
            result_msg = "全部失败 -> 保持原策略"
        
        report_buffer.append("-" * 50)
        report_buffer.append(f"测试结论: {result_msg}")
        report_buffer.append(f"{'='*42}\n")

        # 4. 【关键步骤】一次性打印完整报告到控制台
        # 使用 join 将所有行合并为一个大字符串
        full_report = "\n".join(report_buffer)
        
        # 使用 ctx.log.alert 让它在 mitmproxy 日志中变成红色/高亮，更显眼
        ctx.log.alert(full_report)

        # 解锁
        with self.lock:
            self.testing_flags.remove(suffix)

